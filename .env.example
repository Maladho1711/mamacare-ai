# ═══════════════════════════════════════════════════════════════════════════
# MamaCare AI — Variables d'environnement
# ═══════════════════════════════════════════════════════════════════════════
#
# ⚠️ Architecture : depuis la migration Supabase Edge Functions (avril 2026),
#    le backend NestJS est OBSOLÈTE. Toutes les variables serveur vivent
#    désormais dans les "Secrets" de la Edge Function Supabase.
#
#    Configuration via : bash supabase/setup-secrets.sh
#
# ─── Frontend (Vercel) ───────────────────────────────────────────────────────
# Ces variables doivent être définies sur Vercel :
#   Settings → Environment Variables → Production

NEXT_PUBLIC_SUPABASE_URL=https://jnkabdrqmdgefamahysc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=https://mamacare-ai.vercel.app

# ⚠️ NEXT_PUBLIC_API_URL n'est PLUS nécessaire : l'URL de l'API est dérivée
# automatiquement de NEXT_PUBLIC_SUPABASE_URL + /functions/v1/api.
# Laisse vide ou supprime-la de Vercel.
# NEXT_PUBLIC_API_URL=

# Mode dev frontend (active les boutons login direct) — NE PAS activer en prod
NEXT_PUBLIC_DEV_MODE=false


# ─── Dev local uniquement (apps/api — BACKEND LEGACY, désormais inutile) ─────
# Conservé pour référence. Ces variables vivent maintenant dans Supabase.

NODE_ENV=development
DEV_MODE=true
DEV_MODE_SECRET=

SUPABASE_SERVICE_ROLE_KEY=

ANTHROPIC_API_KEY=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
AFRICA_TALKING_API_KEY=
AFRICA_TALKING_USERNAME=

INTERNAL_CRON_SECRET=

# VAPID pour notifications push (à générer avec : npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@improove.co
